{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(git rev-parse:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run python:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "Bash(curl:*)",
      "Bash(GIT_EDITOR=true git diff:*)",
      "Bash(GIT_EDITOR=true git status:*)",
      "Bash(GIT_EDITOR=true git log:*)",
      "Bash(ls:*)",
      "Bash(npm test)",
      "Bash(make test)",
      "Bash(python3 -m pytest tests/test_api.py::TestNewSession::test_session_is_created -x)",
      "Bash(uv add:*)",
      "Bash(uv pip:*)",
      "Skill(security-reviewer:*)",
      "Bash(git log:*)",
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
