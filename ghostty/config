# visual
background-opacity = 0.95
cursor-color = #ff00ff
font-family = Source Code Pro Bold for Powerline
font-size = 16
font-style = Bold
font-thicken = true
font-thicken-strength = 255
macos-icon = custom-style
macos-icon-frame = aluminum
macos-icon-ghost-color = DarkGreen
macos-icon-screen-color = black
theme = Solarized Dark Higher Contrast
window-padding-color = extend
window-theme = ghostty

# window-titlebar-background
window-titlebar-foreground = ForestGreen

# keys
macos-option-as-alt = true
keybind = opt+d=new_split:down
keybind = opt+r=new_split:right

# behaviors
auto-update = check
quit-after-last-window-closed = true


